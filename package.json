{
  "name": "chatgpt-local-bridge",
  "version": "0.1.0",
  "description": "Terminal CLI that bridges ChatGPT browser conversations with local machine tools via MCP",
  "type": "module",
  "bin": {
    "bridge": "./dist/bin/bridge.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/bin/bridge.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "chatgpt",
    "mcp",
    "local-tools",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.3",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.4.2",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.12",
    "knip": "^6.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.2"
  }
}
